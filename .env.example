# ===========================================
# CARBONPULSE - ENVIRONMENT CONFIGURATION
# ===========================================
# SECURITY WARNING: Never commit actual secrets to version control!
# Copy this file to .env and fill in real values

# ===========================================
# CRITICAL SECURITY CONFIGURATION
# ===========================================

# Session Secret (REQUIRED - Application won't start without it)
# Used for signing session cookies to prevent tampering
# MUST be at least 32 characters of random data
# Generate with: openssl rand -base64 32
# NEVER use the example value in production!
SESSION_SECRET=

# ===========================================
# API KEYS (Optional - for enhanced features)
# ===========================================

# Google AI API Key (for AI-powered recommendations)
GOOGLE_AI_API_KEY=

# Google Maps API Key (for location-based features)
GOOGLE_MAPS_API_KEY=

# Custom LLM API Key (for carbon insights)
LLM_API_KEY=

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Database URL (for production database)
# Development uses file-based JSON database
DATABASE_URL=

# ===========================================
# ENVIRONMENT
# ===========================================

# Application environment (development, staging, production)
NODE_ENV=development

# ===========================================
# SECURITY BEST PRACTICES
# ===========================================
# ✓ Use different secrets for dev/staging/production
# ✓ Rotate secrets every 90 days minimum
# ✓ Never share secrets via Slack/email/chat
# ✓ Use secrets manager in production (AWS Secrets Manager, Vault)
# ✓ Limit secret access to authorized personnel only
# ✓ Monitor secret usage and audit access logs
# ✓ Revoke compromised secrets immediately

# ===========================================
# HOW TO GENERATE SECURE SECRETS
# ===========================================

# macOS/Linux:
#   openssl rand -base64 32

# Windows PowerShell:
#   -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 32 | % {[char]$_})

# Node.js:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# Python:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# ===========================================
# TROUBLESHOOTING
# ===========================================

# Error: "SESSION_SECRET environment variable is not set"
# Solution: Generate a secret using commands above and set in .env file

# Error: "Session secret must be at least 32 characters"
# Solution: Your secret is too short. Generate a longer one.

# Error: "Invalid session cookie"
# Solution: Session secret changed. Users need to log in again.
